DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lecture_room"
JWT_SECRET="dev-only-change-to-32chars-minimum-secret-key"
JWT_EXPIRES_IN=7d
CORS_ORIGIN=*
PORT=3000
HOST=0.0.0.0
# Temporary-use cutoff (minutes before class). Notifications + policy.
CUTOFF_MINUTES=10
# Advance in-app reminder: hours before class start (0 = disabled).
ADVANCE_REMINDER_HOURS=24

# Campus Assistant — LLM API (required for POST /ai/chat). Never commit real keys.
OPENROUTER_API_KEY=
# Free shared routers trade quality/latency for cost; for production set a specific capable model via your provider.
OPENROUTER_MODEL=openrouter/free
# Optional attribution for OpenRouter rankings
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=Lecture Room Status
# Example curl: scripts/ai-chat-example.sh (set API_URL and JWT).
# V2 scenarios: scripts/ai-v2-scenarios.sh

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  student
  teacher
  admin
}

enum BookingStatus {
  booked
  cancelled
}

enum AlertSubscriptionStatus {
  active
  triggered
  expired
  cancelled
}

enum EventType {
  lecture
  exam
  tutor
  defense
  lab
  presentation
}

enum NotificationType {
  advance
  class_start
  cutoff_warning
  cancelled
}

enum RoomType {
  lecture_hall
  lab
  office
  seminar
  other
}

enum AssistantProposalStatus {
  pending
  confirmed
  cancelled
  expired
}

model Faculty {
  id        String   @id @default(uuid())
  name      String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  departments Department[]
  users       User[]
}

model Department {
  id        String   @id @default(uuid())
  name      String
  facultyId String   @map("faculty_id")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  faculty          Faculty           @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  users            User[]
  courseOfferings  CourseOffering[]
  crAssignments    CrAssignment[]

  @@unique([facultyId, name])
  @@index([facultyId])
}

model AcademicYear {
  id        String   @id @default(uuid())
  name      String
  startDate DateTime @map("start_date") @db.Date
  endDate   DateTime @map("end_date") @db.Date
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  courseOfferings CourseOffering[]
  crAssignments   CrAssignment[]
}

/// Catalog course (name + code only). Assignments to dept/year/section are CourseOffering rows.
model Course {
  id          String   @id @default(uuid())
  courseCode  String?  @map("course_code")
  courseName  String   @map("course_name")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  offerings CourseOffering[]

  @@index([courseCode])
  @@index([courseName])
}

/// A course offered in a given academic year to a department cohort (year + optional section).
model CourseOffering {
  id                String   @id @default(uuid())
  courseId          String   @map("course_id")
  academicYearId    String   @map("academic_year_id")
  departmentId      String   @map("department_id")
  year              Int
  section           String?
  teacherUserId     String?  @map("teacher_user_id")
  createdByCrUserId String?  @map("created_by_cr_user_id")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  course       Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  department   Department   @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  teacher      User?        @relation("OfferingTeacher", fields: [teacherUserId], references: [id])
  createdByCr  User?        @relation("OfferingCrCreated", fields: [createdByCrUserId], references: [id])

  bookings Booking[]

  @@index([academicYearId, departmentId, year])
  @@index([teacherUserId])
}

model User {
  id                  String   @id @default(uuid())
  studentId           String   @unique @map("student_id")
  name                String
  email               String?
  passwordHash        String   @map("password_hash")
  role                Role
  gender              String?
  facultyId           String?  @map("faculty_id")
  departmentId        String?  @map("department_id")
  program             String?
  fieldOfStudy        String?  @map("field_of_study")
  admissionType       String?  @map("admission_type")
  year                Int?
  section             String?
  forcePasswordChange Boolean  @default(false) @map("force_password_change")
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  faculty  Faculty?  @relation(fields: [facultyId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])

  courseOfferingsTeaching CourseOffering[] @relation("OfferingTeacher")
  courseOfferingsCreated  CourseOffering[] @relation("OfferingCrCreated")

  crAssignments CrAssignment[]
  bookingsAsBooker Booking[] @relation("BookingBookedBy")
  roomAlertSubs    RoomAlertSubscription[]
  notifications    Notification[]
  assistantProposals AssistantProposal[]
}

model Building {
  id         String  @id @default(uuid())
  name       String  @map("building_name")
  floorCount Int     @map("floor_count")
  isActive   Boolean @default(true) @map("is_active")

  rooms Room[]
}

model Room {
  id            String   @id @default(uuid())
  roomNumber    String   @map("room_number")
  buildingId    String   @map("building_id")
  floorIndex    Int      @map("floor_index")
  capacity      Int
  roomType      RoomType @default(lecture_hall) @map("room_type")
  hasProjector  Boolean  @default(false) @map("has_projector")
  hasInternet   Boolean  @default(false) @map("has_internet")
  hasPower      Boolean  @default(true) @map("has_power")
  equipmentJson String?  @map("equipment_json")
  isActive      Boolean  @default(true) @map("is_active")

  building Building  @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  bookings Booking[]
  alerts   RoomAlertSubscription[]

  @@unique([buildingId, roomNumber])
  @@index([buildingId])
}

model Booking {
  id                      String        @id @default(uuid())
  roomId                  String        @map("room_id")
  courseOfferingId        String        @map("course_offering_id")
  bookedByUserId          String        @map("booked_by_user_id")
  eventType               EventType     @default(lecture) @map("event_type")
  startTime               DateTime      @map("start_time")
  endTime                 DateTime      @map("end_time")
  status                  BookingStatus
  nextBookingPreference   Boolean       @default(false) @map("next_booking_preference")
  createdAt               DateTime      @default(now()) @map("created_at")
  updatedAt               DateTime      @updatedAt @map("updated_at")

  room           Room           @relation(fields: [roomId], references: [id], onDelete: Cascade)
  courseOffering CourseOffering @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)
  bookedBy       User           @relation("BookingBookedBy", fields: [bookedByUserId], references: [id])
  notifications  Notification[]

  @@index([roomId, startTime])
  @@index([roomId, status])
}

model CrAssignment {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  academicYearId String   @map("academic_year_id")
  departmentId   String   @map("department_id")
  year           Int
  section        String?
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  department   Department   @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@index([userId, academicYearId])
  @@index([departmentId, year, section])
}

model RoomAlertSubscription {
  id                  String                  @id @default(uuid())
  userId              String                  @map("user_id")
  roomId              String                  @map("room_id")
  notifyBeforeMinutes Int                     @default(10) @map("notify_before_minutes")
  expiresAt           DateTime                @map("expires_at")
  status              AlertSubscriptionStatus
  notificationId      String?                 @map("notification_id")
  createdAt           DateTime                @default(now()) @map("created_at")
  updatedAt           DateTime                @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([userId, roomId])
}

model AssistantProposal {
  id         String                  @id @default(cuid())
  userId     String                  @map("user_id")
  action     String
  payloadJson String                 @map("payload_json")
  summary    String
  status     AssistantProposalStatus @default(pending)
  expiresAt  DateTime                @map("expires_at")
  confirmedAt DateTime?              @map("confirmed_at")
  createdAt  DateTime                @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, expiresAt])
}

model Notification {
  id            String           @id @default(uuid())
  userId        String           @map("user_id")
  type          NotificationType
  title         String
  message       String
  scheduledTime DateTime?        @map("scheduled_time")
  deliveredAt   DateTime?        @map("delivered_at")
  isRead        Boolean          @default(false) @map("is_read")
  bookingId     String?          @map("booking_id")
  createdAt     DateTime         @default(now()) @map("created_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([bookingId])
  @@map("notifications")
}

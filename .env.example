# Copy to .env and fill in. Used by docker compose at repo root.

POSTGRES_PASSWORD=change-me-strong-password
JWT_SECRET=replace-with-at-least-32-random-characters-here
API_PORT=3000
# Comma-separated origins for browser clients, or * for mobile dev
CORS_ORIGIN=*
# Optional: Campus Assistant via Groq (passed into api service). If set, OpenRouter vars are ignored.
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

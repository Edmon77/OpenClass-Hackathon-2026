# Copy to .env and fill in. Used by docker compose at repo root.

POSTGRES_PASSWORD=change-me-strong-password
# Optional: for `npm run db:push` / `db:seed` from server/ without server/.env — same password as above.
# DATABASE_URL=postgresql://postgres:change-me-strong-password@localhost:5432/lecture_room
JWT_SECRET=replace-with-at-least-32-random-characters-here
API_PORT=3000
# Browser admin on another port needs CORS. * = reflect caller Origin (works with credentials). Or list: https://a.com,http://IP:8080
CORS_ORIGIN=*
# Campus Assistant: set GROQ_API_KEY and/or OPENROUTER_API_KEY. If both are set, Groq is tried first;
# OpenRouter is used automatically when Groq returns rate limits (429 / TPM) or 503.
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.1-8b-instant
